:root {
}

.hidden {
    display: none;
}

#vertical-list {
    flex-direction: column;
    justify-content: flex-end;
    flex-grow: 1;
}

.horizontal-list {
    flex-direction: row;
    justify-content: center;
    flex-shrink: 1;
    height: 50px;
}

.button {
    margin: 1px;
    flex-grow: 1;
    flex-shrink: 1;
    max-width: 380px;
    background-color: rgb(202, 97, 195);
    color: white;
    border-radius: 15px;
}

.button .unity-image {
    padding: 2px;
}